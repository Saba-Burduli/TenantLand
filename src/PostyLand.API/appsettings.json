{
  "ConnectionStrings": {
    "MainDb": "Host=localhost;Port=5432;Database=postyland_main;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "SigningKey": "replace-with-at-least-32-characters-long-production-key",
    "Issuer": "postyland-api",
    "Audience": "postyland-clients"
  },
  "TenantResolution": {
    "RootDomain": "postyland.com",
    "SubdomainHeader": "X-Tenant-Subdomain",
    "ReservedSubdomains": [ "api", "www" ],
    "BypassPathPrefixes": [ "/health", "/hangfire", "/openapi", "/swagger", "/migrations", "/api/payments", "/api/tenants", "/api/tenants/register", "/api/admin", "/auth" ]
  },
  "ExternalAuth": {
    "FrontendRedirectUri": "https://app.postyland.com/auth/callback",
    "StateTtlMinutes": 10,
    "Google": {
      "ClientId": "",
      "ClientSecret": "",
      "RedirectUri": "https://api.postyland.com/auth/google/callback"
    },
    "Microsoft": {
      "ClientId": "",
      "ClientSecret": "",
      "TenantId": "common",
      "RedirectUri": "https://api.postyland.com/auth/microsoft/callback"
    }
  },
  "Encryption": {
    "Key": "replace-with-strong-encryption-key"
  },
  "TenantDatabase": {
    "Template": "Host=localhost;Port=5432;Username=postgres;Password=postgres;Database=tenant_template"
  },
  "Provisioning": {
    "PostgresAdminConnectionString": "Host=localhost;Port=5432;Database=postgres;Username=postgres;Password=postgres",
    "HostedZoneId": "",
    "RootDomain": "postyland.com",
    "DnsRecordTarget": "",
    "AwsRegion": "us-east-1",
    "BucketPrefix": "postyland",
    "DisableExternalProvisioning": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
