{
  "ConnectionStrings": {
    "MainDb": "Host=localhost;Port=5432;Database=postyland_main_dev;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "SigningKey": "replace-with-at-least-32-characters-long-development-key",
    "Issuer": "postyland-api-dev",
    "Audience": "postyland-clients-dev"
  },
  "TenantResolution": {
    "RootDomain": "postyland.com",
    "SubdomainHeader": "X-Tenant-Subdomain",
    "ReservedSubdomains": [ "api", "www" ],
    "BypassPathPrefixes": [ "/health", "/hangfire", "/openapi", "/swagger", "/api/tenants/register", "/api/admin" ]
  },
  "Encryption": {
    "Key": "postyland-dev-encryption-key"
  },
  "TenantDatabase": {
    "Template": "Host=localhost;Port=5432;Username=postgres;Password=postgres;Database=tenant_template_dev"
  },
  "Provisioning": {
    "PostgresAdminConnectionString": "Host=localhost;Port=5432;Database=postgres;Username=postgres;Password=postgres",
    "HostedZoneId": "",
    "RootDomain": "postyland.com",
    "DnsRecordTarget": "",
    "AwsRegion": "us-east-1",
    "BucketPrefix": "postyland-dev",
    "DisableExternalProvisioning": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
